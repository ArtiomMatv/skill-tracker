# Copy to `.env` for local tooling or Compose overrides (optional).

# Django
# SECRET_KEY=change-me
# DEBUG=0
# ALLOWED_HOSTS=127.0.0.1,localhost,your.render.host
# REQUIRE_AUTH=0

# Database (Compose Postgres profile sets this automatically)
# DATABASE_URL=postgres://skill:skill@db:5432/skilltracker
# DATABASE_SSL_REQUIRE=1

# SQLite in Docker (default dev compose)
# SQLITE_PATH=/data/db.sqlite3

# CORS / CSRF (comma-separated origins when deploying)
# CORS_ALLOWED_ORIGINS=https://your-static.onrender.com,https://your-api.onrender.com
# CSRF_TRUSTED_ORIGINS=https://your-static.onrender.com

# Frontend build-time (Vite)
# VITE_GRAPHQL_URL=https://your-api.onrender.com/graphql/
